
{
  "kind": "collectionType",
  "collectionName": "telegram_users",
  "info": {
    "singularName": "telegram-user",
    "pluralName": "telegram-users",
    "displayName": "Telegram пользователь"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "telegramId": {
      "type": "biginteger",
      "required": true,
      "unique": true
    },
    "username": {
      "type": "string"
    },
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "currentLevel": {
      "type": "integer",
      "default": 1,
      "min": 1
    },
    "totalScore": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "completedExercises": {
      "type": "json",
      "default": []
    },
    "completedTests": {
      "type": "json",
      "default": []
    },
    "lastActiveAt": {
      "type": "datetime"
    },
    "isBlocked": {
      "type": "boolean",
      "default": false
    }
  }
}
