# PostgreSQL
POSTGRES_USER=qazaq
POSTGRES_PASSWORD=changeme

# Bot
BOT_TOKEN=your_telegram_bot_token
ALEM_API_KEY=your_alem_api_key

# Admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_SESSION_SECRET=generate_with_openssl_rand_hex_32

# Database URL for admin Prisma (schema=admin keeps tables separate from other schemas)
DATABASE_URL=postgresql://qazaq:changeme@localhost:5432/qazaq?schema=admin

# Shared secret for bot→admin API calls (generate with: openssl rand -hex 32)
ADMIN_BOT_SECRET=generate_with_openssl_rand_hex_32
